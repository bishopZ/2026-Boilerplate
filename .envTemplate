# Environment Variables Template
# Copy this file to .env to get started: cp .envTemplate .env
# Default values work for local development. Change SESSION_SECRET and LOCAL_STORAGE_KEY before deploying to production.

# Local Storage Encryption Key
# Used to encrypt data stored in the browser's localStorage
LOCAL_STORAGE_KEY=local-dev-storage-key

# JWT / Session Secret
# Used to sign JWT authentication tokens
SESSION_SECRET=local-dev-session-secret

# Node Environment
# Options: development, production
NODE_ENV=development

# Server Port (optional, defaults to 3000)
# PORT=3000

# Login Rate Limiting (optional)
# Max failed login attempts per window for each IP
# LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
# Login rate-limit window in milliseconds (15 min default)
# LOGIN_RATE_LIMIT_WINDOW_MS=900000

# Client feature flags (optional)
# Comma-separated key=value list consumed by the runtime feature-flag hook.
# Example: VITE_FEATURE_FLAGS="newNav=true,newCheckout=false"
# VITE_FEATURE_FLAGS=

# Auth backing profile (optional starter mode)
# local     -> uses local starter account in code (default)
# supabase  -> starter profile for Supabase integration
# postgres  -> starter profile for Postgres user-table integration
# AUTH_PROFILE=local

# Optional placeholders for future real-auth profile wiring:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# DATABASE_URL=
